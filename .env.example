# ─── CockroachDB (memory) ──────────────────────────────────────────
# Full connection string the app/pipeline uses to WRITE detections
DATABASE_URL=postgresql://<user>:<password>@<host>:26257/defaultdb?sslmode=require

# Read-only user used by the MCP server (SELECT only)
READONLY_DATABASE_URL=postgresql://aura_readonly:<password>@<host>:26257/defaultdb?sslmode=require

# ─── AWS / Amazon Bedrock (embeddings) ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-image-v1

# ─── Storage (forensic report PDFs) ────────────────────────────────
S3_BUCKET=<your-bucket>

# NOTE: this is a TEMPLATE only. Never commit the real .env.
